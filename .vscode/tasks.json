{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PlatformIO: Build",
            "type": "process",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\platformio.exe",
            "args": ["run"],
            "problemMatcher": ["$platformio"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "PlatformIO: Upload",
            "type": "process",
            "command": "${env:USERPROFILE}\\.platformio\\penv\\Scripts\\platformio.exe",
            "args": ["run", "--target", "upload"],
            "problemMatcher": ["$platformio"],
            "group": "none"
        }
    ]
}
